// 退款记录表
model OrderRefund {
  id            String  @id @default(cuid()) // 内部主键
  afterSaleCode String  @map("after_sale_code") // 售后编号（必填，业务唯一标识）
  orderId       String? @map("order_id") // 所属订单ID

  refundChannel   RefundChannel? @map("refund_channel") // 退款渠道
  approvalUrl     String?        @map("approval_url") // 审批链接
  createdBy       String?        @map("created_by") // 登记人（系统用户ID）
  refundAmount    Int?           @map("refund_amount") // 退款金额（最小单位：分），与 Order.amount 保持一致
  refundReason    String?        @map("refund_reason") // 退款原因描述
  benefitUsedDays Int?           @map("benefit_used_days") // 实际权益使用天数（用于计算退款比例，从 benefitStart 到退款申请日）
  applicantName   String?        @map("applicant_name") // 申请人姓名
  status          RefundStatus   @default(PENDING) @map("status") // 退款状态

  financialNote   String? @map("financial_note") // 结算备注
  parentId        String? @map("parent_id") // 父退款记录ID（用于分期退款或部分退款场景）
  productCategory String? @map("product_category") // 产品类别（冗余存储，用于财务报表筛选）

  submittedAt        DateTime? @map("submitted_at") @db.Timestamptz(6) // 提交时间
  refundedAt         DateTime? @map("refunded_at") @db.Timestamptz(6) // 退款时间
  financialSettledAt DateTime? @map("financial_settled_at") @db.Timestamptz(6) // 财务结算时间

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6) // 删除时间（软删除）

  // 关联关系
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  creator      User?         @relation("RefundCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  parentRefund OrderRefund?  @relation("RefundHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  childRefunds OrderRefund[] @relation("RefundHierarchy")

  // ========= 约束/唯一性 =========

  // 售后编号唯一
  @@unique([afterSaleCode], map: "uk_order_refunds_after_sale_code")
  // 订单维度唯一（同一订单的售后编号唯一）
  @@unique([orderId, afterSaleCode], map: "uk_order_refunds_order_after_sale_code")
  // ========= 索引（按真实查询习惯组织） =========
  // 外键索引（必须）
  @@index([orderId], map: "idx_order_refunds_order_id")
  @@index([createdBy], map: "idx_order_refunds_created_by")
  @@index([parentId], map: "idx_order_refunds_parent_id")
  // 状态查询
  @@index([status], map: "idx_order_refunds_status")
  // 时间查询
  @@index([submittedAt], map: "idx_order_refunds_submitted_at")
  @@index([refundedAt], map: "idx_order_refunds_refunded_at")
  // 复合索引：财务结算报表查询
  @@index([status, submittedAt], map: "idx_order_refunds_status_submitted_at")
  @@index([status, financialSettledAt], map: "idx_order_refunds_status_financial_settled_at")
  // 订单维度查询
  @@index([orderId, status], map: "idx_order_refunds_order_status")
  @@index([orderId, submittedAt], map: "idx_order_refunds_order_submitted_at")
  // 软删除过滤（常用）
  @@index([deletedAt], map: "idx_order_refunds_deleted_at")
  @@map("order_refunds")
}

// 退款状态枚举
enum RefundStatus {
  PENDING // 未结算
  SETTLED // 已结算
}

// 退款渠道枚举
enum RefundChannel {
  DOUYIN // 抖音平台退款
  ALIPAY // 支付宝退款
  WECHAT // 微信退款
  STRIPE // Stripe 退款
  PAYPAL // PayPal 退款
  MANUAL // 人工退款
  OTHER // 其他
}
