model Skill {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String
  license       String?
  compatibility String?
  metadataJson  String?
  allowedTools  String?

  bodyMarkdown  String
  rawSkillMd    String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}
