// API Key 状态枚举
enum ApiKeyStatus {
  ACTIVE // 活跃状态
  REVOKED // 已撤销
  EXPIRED // 已过期
}

// API Key 表
model ApiKey {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id") // 所属组织ID
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name   String // API Key 名称
  prefix String @unique // Key 前缀（用于快速查找）
  keyHash String @map("key_hash") // Key 的 HMAC-SHA256 哈希值
  last4  String // Key 最后4位（用于显示）

  status ApiKeyStatus @default(ACTIVE) // Key 状态
  scopes String[]     @default([]) // 权限范围

  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6) // 过期时间
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6) // 撤销时间
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6) // 最后使用时间

  createdBy     String? @map("created_by") // 创建者用户ID
  createdByUser User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Key 轮换关系（自关联）
  rotatedFromId String?  @unique @map("rotated_from_id") // 从哪个 Key 轮换而来
  rotatedFrom   ApiKey?  @relation("KeyRotation", fields: [rotatedFromId], references: [id], onDelete: SetNull)
  rotatedTo     ApiKey?  @relation("KeyRotation") // 轮换到哪个 Key

  // 使用日志关联
  usageLogs ApiKeyUsageLog[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([organizationId, status]) // 组织+状态查询优化
  @@index([organizationId, createdAt]) // 组织+创建时间查询优化
  @@index([status, expiresAt]) // 过期 Key 清理查询优化
  @@index([createdBy]) // 创建者查询优化
  @@map("api_keys")
}

// API Key 使用日志表
model ApiKeyUsageLog {
  id             String       @id @default(cuid())
  apiKeyId       String       @map("api_key_id") // API Key ID
  apiKey         ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id") // 所属组织ID
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  method     String // HTTP 方法
  path       String // 请求路径
  statusCode Int    @map("status_code") // HTTP 状态码
  latencyMs  Int    @map("latency_ms") // 请求延迟（毫秒）

  ip        String? // 请求 IP 地址
  userAgent String? @map("user_agent") @db.Text // User-Agent
  error     String? @db.Text // 错误信息（如果有）

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([apiKeyId, createdAt]) // API Key + 时间查询优化
  @@index([organizationId, createdAt]) // 组织 + 时间查询优化
  @@index([createdAt]) // 时间范围查询优化
  @@map("api_key_usage_logs")
}
