model Conversation {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  messages  Message[]
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}
