// 订单表
model Order {
  id                   String    @id @default(cuid()) // 内部主键
  orderCode            String    @unique @map("order_code") // 系统生成的订单编号
  orderNumber          String    @unique @map("order_number") // 订单号码（对外显示）
  externalOrderId      String?   @map("external_order_id") // 外部平台订单编号
  externalOrderData    Json?     @db.JsonB // 外部订单数据
  productId            String?   @map("product_id") // 产品ID（外键）
  productName          String?   @map("product_name") // 产品标题（冗余存储）
  customerEmail        String?   @map("customer_email") // 用户邮箱
  customerPhone        String?   @map("customer_phone") // 订单手机号
  customerPhoneCode    String?   @map("customer_phone_code") // 手机号区号
  userId               String?   @map("user_id") // 用户ID（外键）
  channelId            Int?      @map("channel_id") // 渠道ID（外键）
  currentOwnerId       String?   @map("current_owner_id") // 当前负责人（系统用户ID）
  financialCloserId    String?   @map("financial_closer_id") // 财务结单人（系统用户ID）
  financialClosedAt    DateTime? @map("financial_closed_at") // 财务结单时间
  financialClosed      Boolean   @default(false) @map("financial_closed") // 是否财务结单
  amount               Int // 金额（分为单位）
  currency             Currency? // 币种
  amountCny            Int // 折算后的人民币金额
  
  paidAt               DateTime? // 支付时间
  effectiveDate        DateTime? @db.Date // 生效时间
  benefitStartDate     DateTime? @db.Date // 权益开始时间
  benefitDurationDays  Int? // 权益时长（天）
  activeDays           Int? // 在籍时长（天）
  benefitDaysRemaining Int? // 权益剩余时间（天）

  // 关联关系
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  user            User?         @relation("UserOrders", fields: [userId], references: [id], onDelete: SetNull)
  channel         Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  currentOwner    User?         @relation("CurrentOwnerOrders", fields: [currentOwnerId], references: [id], onDelete: SetNull)
  financialCloser User?         @relation("FinancialCloserOrders", fields: [financialCloserId], references: [id], onDelete: SetNull)
  refunds         OrderRefund[] // 订单的退款记录

  createdAt DateTime @default(now()) // 创建时间
  updatedAt DateTime @updatedAt // 更新时间

  @@index([userId]) // 用户订单查询
  @@index([productId]) // 产品订单查询
  @@index([channelId]) // 渠道订单查询
  @@index([currentOwnerId]) // 负责人查询
  @@index([financialClosed]) // 财务状态查询
  @@index([paidAt]) // 支付时间查询
  @@index([effectiveDate]) // 生效时间查询
  @@index([userId, paidAt]) // 用户订单历史
  @@index([financialClosed, paidAt]) // 财务报表查询
  @@map("orders")
}

// 币种枚举
enum Currency {
  CNY // 人民币
  USD // 美元
  EUR // 欧元
  GBP // 英镑
  JPY // 日元
  HKD // 港币
  TWD // 台币
  SGD // 新加坡元
  AUD // 澳元
  CAD // 加元
}
